CREATE TEMP TABLE __query__result__ AS SELECT R_1.col0 as x, R_1.col1 as y, R_2.col1 as z FROM R as R_1, R as R_2, R as R_3 WHERE R_1.col0 = R_3.col1 and R_1.col1 = R_2.col0 and R_2.col1 = R_3.col0;
